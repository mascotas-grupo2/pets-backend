# Local development (Postgres exposed on host port 5433)
DATABASE_URL="postgresql://pets:pets@localhost:5433/pets_db"

# Inside Docker Compose (use the service name as the host)
# DATABASE_URL="postgresql://pets:pets@postgres:5432/pets_db"

PORT=3001

# Keycloak (OpenID Connect)
# Desde la máquina host apuntar a localhost; dentro de docker-compose usar el nombre del servicio.
KEYCLOAK_ISSUER="http://localhost:8080/realms/pets"
# KEYCLOAK_ISSUER="http://keycloak:8080/realms/pets"
KEYCLOAK_AUDIENCE="pets-backend"
