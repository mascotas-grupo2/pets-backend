# Local development (Postgres exposed on host port 5433)
DATABASE_URL="postgresql://pets:pets@localhost:5433/pets_db"

# Inside Docker Compose (use the service name as the host)
# DATABASE_URL="postgresql://pets:pets@postgres:5432/pets_db"
NODE_ENV=development
PORT=3002
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="aHVlbGxpdGFzLXNlY3JldC1qd3Q="
JWT_ISSUER="pets-backend"
JWT_EXPIRES_IN="1h"
COOKIE_SECURE=false

# Keycloak (OpenID Connect)
# Desde la maquina host apuntar a localhost; dentro de docker-compose usar el nombre del servicio.
KEYCLOAK_ISSUER="http://localhost:8080/realms/pets"
# KEYCLOAK_ISSUER="http://keycloak:8080/realms/pets"
KEYCLOAK_AUDIENCE="pets-backend"
KEYCLOAK_GOOGLE_CLIENT_SECRET="your-google-client-secret-here"


#MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=adminadmin
MINIO_BUCKET=report-images
MINIO_PROFILE_BUCKET=profile
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Chatbot LLM (Groq, free tier sin tarjeta en https://console.groq.com/keys)
GROQ_API_KEY=""
GROQ_MODEL=llama-3.3-70b-versatile
CHAT_MAX_TOOL_ITERATIONS=5
CHAT_HISTORY_LIMIT=20
CHAT_SESSION_TTL_MINUTES=60

#SMTP (Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo@correo.com
SMTP_PASS=**** **** **** ****
SMTP_FROM=Huellitas Unidas
