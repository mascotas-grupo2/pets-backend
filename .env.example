# Local development (Postgres exposed on host port 5433)
DATABASE_URL="postgresql://pets:pets@localhost:5433/pets_db"

# Inside Docker Compose (use the service name as the host)
# DATABASE_URL="postgresql://pets:pets@postgres:5432/pets_db"
NODE_ENV=development
PORT=3002
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="aHVlbGxpdGFzLXNlY3JldC1qd3Q="
JWT_ISSUER="pets-backend"
JWT_EXPIRES_IN="1h"
COOKIE_SECURE=false

# Row-Level Security (multi-tenant defense-in-depth).
# Cuando RLS_ENABLED=true, cada request corre dentro de una transacción que hace
# SET LOCAL ROLE "<RLS_APP_ROLE>" y fija app.current_refugio / app.is_superadmin,
# de modo que Postgres filtra por refugio aunque la capa de aplicación falle.
# Requiere haber corrido la migración AddRowLevelSecurity y que el usuario de
# DATABASE_URL pueda hacer SET ROLE al rol de aplicación (la migración hace
# GRANT "<RLS_APP_ROLE>" TO CURRENT_USER). Dejar en false desactiva el backstop
# y la aislación queda solo a nivel aplicación (scoping en los controllers).
RLS_ENABLED=false
RLS_APP_ROLE=pets_app

# Keycloak (OpenID Connect)
# Desde la maquina host apuntar a localhost; dentro de docker-compose usar el nombre del servicio.
KEYCLOAK_ISSUER="http://localhost:8080/realms/pets"
# KEYCLOAK_ISSUER="http://keycloak:8080/realms/pets"
KEYCLOAK_AUDIENCE="pets-backend"
KEYCLOAK_GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
KEYCLOAK_GOOGLE_CLIENT_ID="your-google-client-id-here"

#MinIO
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=adminadmin
MINIO_BUCKET=report-images
MINIO_PROFILE_BUCKET=profile
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# Chatbot LLM (Groq, free tier sin tarjeta en https://console.groq.com/keys)
GROQ_API_KEY=""
GROQ_MODEL=llama-3.1-8b-instant
CHAT_MAX_TOOL_ITERATIONS=5
CHAT_HISTORY_LIMIT=12
CHAT_SESSION_TTL_MINUTES=60

#SMTP (Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=correo@correo.com
SMTP_PASS=**** **** **** ****
SMTP_FROM=Huellitas Unidas <correo@correo.com>
SMTP_SECURE=false
