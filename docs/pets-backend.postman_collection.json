        {
          "name": "POST /api/auth/login (sets token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.token) { pm.collectionVariables.set(\"token\", json.token); }",
                  "if (json && json.refreshToken) { pm.collectionVariables.set(\"refreshToken\", json.refreshToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
